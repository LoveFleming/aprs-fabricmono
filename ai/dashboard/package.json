{
  "name": "ai-factory-portal-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "pregenerate-specs": "node scripts/generate-specs-index.cjs",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:opencode\"",
    "build": "npm run pregenerate-specs && tsc -b && vite build",
    "dev:vite": "vite",
    "dev:opencode": "opencode serve --port 4096",
    "preview": "vite preview"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.2.12",
    "@tailwindcss/typography": "^0.5.19",
    "lucide-react": "^1.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.1"
  }
}
