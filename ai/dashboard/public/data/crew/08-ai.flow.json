                },
                {
                    "key": "steps",
                    "label": "流程步驟",
                    "placeholder": "Controller → Service → Orchestrator → Node...",
                    "type": "textarea",
                    "required": true
                }
            ]
        },
        {
            "name": "Dependency graph analysis",
            "inputFields": [
                {
                    "key": "nodes",
                    "label": "Node 列表",
                    "placeholder": "列出所有 node 和依賴關係...",
                    "type": "textarea",
                    "required": true
                }
            ]
        },
        {
            "name": "Retry/fallback design",
            "inputFields": [
                {
                    "key": "step",
                    "label": "失敗步驟",
