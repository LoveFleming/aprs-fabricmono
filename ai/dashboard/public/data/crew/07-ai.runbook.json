{
    "id": "ai.runbook",
    "title": "Runbook Maker",
    "codename": "RunbookMedic",
    "imageUrl": "/crew/runbook_medic_1772459328816.png",
    "skills": [
        {
            "name": "Map error codes to runbooks",
            "inputFields": [
                {
                    "key": "errorCode",
                    "label": "Error Code",
                    "placeholder": "例如：SYS_CTRL_001",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "errorDesc",
                    "label": "錯誤描述",
                    "placeholder": "這個錯誤發生在什麼情境...",
                    "type": "textarea",
                    "required": true
                }
            ]
        },
        {
            "name": "Template troubleshooting steps",
            "inputFields": [
                {
                    "key": "issue",
                    "label": "問題描述",
                    "placeholder": "發生什麼問題...",
                    "type": "textarea",
                    "required": true
                },
                {
                    "key": "env",
                    "label": "環境",
                    "placeholder": "production / staging",
                    "type": "select",
                    "options": [
                        "production",
                        "staging",
                        "development"
                    ],
                    "required": false
                }
            ]
        },
        {
            "name": "Closed-loop updates",
            "inputFields": [
                {
                    "key": "incidentId",
                    "label": "Incident ID",
                    "placeholder": "inc-2026-xx-xxx",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "resolution",
                    "label": "解決方式",
                    "placeholder": "怎麼修的...",
                    "type": "textarea",
                    "required": true
                }
            ]
        }
    ],
    "outputs": [
        "runbook.md",
        "runbook_fix_pr.md"
    ],
    "engine": "cline",
    "risk": "safe",
    "description": "Keeps operational knowledge bases up-to-date and actionable.",
    "promptTemplate": "You are RunbookMedic, a specialized AI employee (Runbook Maker).\n\nRole description: Keeps operational knowledge bases up-to-date and actionable.\n\nYour specific skills include:\n- Map error codes to runbooks\n- Template troubleshooting steps\n- Closed-loop updates (Q4)\n\nYou are expected to produce the following outputs:\n- runbook.md\n- runbook_fix_pr.md\n\nStay in character and assist the user specifically using your skills and role boundaries."
}