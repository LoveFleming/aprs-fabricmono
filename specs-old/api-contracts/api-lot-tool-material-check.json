{
  "apiContract": {
    "name": "api-lot-tool-material-check",
    "version": "1.0.0",
    "summary": "Check whether the input lot, tool, and material combination is valid",
    "owner": "ai-factory",
    "status": "draft"
  },
  "endpoint": {
    "method": "POST",
    "path": "/api/lot-tool-material-check"
  },
  "authentication": {
    "required": true,
    "type": "bearerToken"
  },
  "request": {
    "bodySchema": {
      "type": "object",
      "required": [
        "traceId",
        "fabId",
        "lotId",
        "toolId",
        "operationId",
        "materialIds"
      ],
      "properties": {
        "traceId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "fabId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30
        },
        "lotId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "toolId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "operationId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "recipeId": {
          "type": "string",
          "maxLength": 50
        },
        "productId": {
          "type": "string",
          "maxLength": 50
        },
        "materialIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50
          }
        },
        "checkMode": {
          "type": "string",
          "enum": [
            "STRICT",
            "LENIENT"
          ],
          "default": "STRICT"
        },
        "requestedBy": {
          "type": "string",
          "maxLength": 100
        }
      }
    }
  },
  "response": {
    "success": {
      "httpStatus": 200,
      "bodySchema": {
        "type": "object",
        "required": [
          "traceId",
          "checkStatus",
          "lotId",
          "toolId",
          "operationId",
          "matchedMaterialIds",
          "missingMaterialIds",
          "unexpectedMaterialIds"
        ],
        "properties": {
          "traceId": {
            "type": "string"
          },
          "checkStatus": {
            "type": "string",
            "enum": [
              "MATCH",
              "MISMATCH"
            ]
          },
          "lotId": {
            "type": "string"
          },
          "toolId": {
            "type": "string"
          },
          "operationId": {
            "type": "string"
          },
          "recipeId": {
            "type": "string"
          },
          "productId": {
            "type": "string"
          },
          "matchedMaterialIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missingMaterialIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "unexpectedMaterialIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "message": {
            "type": "string"
          },
          "checkedAt": {
            "type": "string",
            "format": "date-time"
          },
          "reference": {
            "type": "object",
            "properties": {
              "specVersion": {
                "type": "string"
              },
              "ruleSetId": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "errors": [
      {
        "httpStatus": 400,
        "errorBody": {
          "errorCode": "BIZ_API_LOT_TOOL_MATERIAL_CHECK_REQUEST_INVALID",
          "errorType": "VALIDATION"
        }
      },
      {
        "httpStatus": 401,
        "errorBody": {
          "errorCode": "AUTH_API_UNAUTHORIZED",
          "errorType": "AUTH"
        }
      },
      {
        "httpStatus": 403,
        "errorBody": {
          "errorCode": "AUTH_API_FORBIDDEN",
          "errorType": "AUTH"
        }
      },
      {
        "httpStatus": 404,
        "errorBody": {
          "errorCode": "BIZ_API_LOT_OR_TOOL_NOT_FOUND",
          "errorType": "NOT_FOUND"
        }
      },
      {
        "httpStatus": 502,
        "errorBody": {
          "errorCode": "EXT_API_MATERIAL_RULE_SERVICE_BAD_RESPONSE",
          "errorType": "DEPENDENCY"
        }
      },
      {
        "httpStatus": 504,
        "errorBody": {
          "errorCode": "EXT_API_MATERIAL_RULE_SERVICE_TIMEOUT",
          "errorType": "TIMEOUT"
        }
      },
      {
        "httpStatus": 500,
        "errorBody": {
          "errorCode": "SYS_API_LOT_TOOL_MATERIAL_CHECK_FAILED",
          "errorType": "SYSTEM"
        }
      }
    ]
  }
}
