{
  "apiContract": {
    "name": "api-hello-world",
    "version": "1.0.0",
    "summary": "A simple greeting AI Node that returns personalized welcome messages",
    "owner": "ai-factory",
    "status": "active"
  },
  "endpoint": {
    "method": "POST",
    "path": "/api/hello-world"
  },
  "authentication": {
    "required": false
  },
  "request": {
    "bodySchema": {
      "type": "object",
      "required": ["traceId"],
      "properties": {
        "traceId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Unique trace ID for tracking"
        },
        "name": {
          "type": "string",
          "maxLength": 50,
          "default": "World",
          "description": "Name to greet"
        },
        "language": {
          "type": "string",
          "enum": ["en", "zh", "ja", "es"],
          "default": "en",
          "description": "Language for the greeting"
        }
      }
    }
  },
  "response": {
    "success": {
      "httpStatus": 200,
      "bodySchema": {
        "type": "object",
        "required": ["traceId", "greeting", "message", "timestamp"],
        "properties": {
          "traceId": {
            "type": "string"
          },
          "greeting": {
            "type": "string",
            "description": "The greeting phrase"
          },
          "message": {
            "type": "string",
            "description": "Full welcome message"
          },
          "language": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "nodeInfo": {
            "type": "object",
            "properties": {
              "nodeId": {
                "type": "string"
              },
              "version": {
                "type": "string"
              },
              "factory": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "errors": [
      {
        "httpStatus": 400,
        "errorBody": {
          "errorCode": "BIZ_HELLO_WORLD_REQUEST_INVALID",
          "errorType": "VALIDATION"
        }
      },
      {
        "httpStatus": 500,
        "errorBody": {
          "errorCode": "SYS_HELLO_WORLD_PROCESSING_FAILED",
          "errorType": "SYSTEM"
        }
      }
    ]
  }
}